@* ── DocumentSnapshot Detail ──────────────────────────────────── *@

<div class="ops-detail-card">
    <div class="ops-detail-card-header">
        <div class="ops-detail-card-icon ops-icon-cyan">📸</div>
        <h4>Document Snapshot</h4>
    </div>
    <div class="ops-detail-card-body">
        <div class="ops-detail-row">
            <span class="ops-detail-label">Revision</span>
            <span class="ops-detail-value">
                <span class="ops-badge ops-badge-cyan">@Item.Revision</span>
            </span>
        </div>
        <div class="ops-detail-row">
            <span class="ops-detail-label">Timestamp</span>
            <span class="ops-detail-value">@Item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss zzz")</span>
        </div>
        <div class="ops-detail-row">
            <span class="ops-detail-label">State Size</span>
            <span class="ops-detail-value ops-mono">@FormatBytes(Item.State.Length)</span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public DocumentSnapshot Item { get; set; } = default!;

    private static string FormatBytes(int length)
    {
        if (length < 1024) return $"{length} B";
        if (length < 1024 * 1024) return $"{length / 1024.0:F1} KB";
        return $"{length / (1024.0 * 1024.0):F2} MB";
    }
}
