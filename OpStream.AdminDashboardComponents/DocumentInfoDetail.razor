@* ── DocumentInfo Detail ──────────────────────────────────────── *@

<div class="ops-detail-card">
    <div class="ops-detail-card-header">
        <div class="ops-detail-card-icon ops-icon-blue">📄</div>
        <h4>Document Info</h4>
    </div>
    <div class="ops-detail-card-body">
        <div class="ops-detail-row">
            <span class="ops-detail-label">Document ID</span>
            <span class="ops-detail-value ops-mono">@Item.DocumentId</span>
        </div>
        <div class="ops-detail-row">
            <span class="ops-detail-label">Revision</span>
            <span class="ops-detail-value">
                <span class="ops-badge ops-badge-blue">@Item.Revision</span>
            </span>
        </div>
        <div class="ops-detail-row">
            <span class="ops-detail-label">Last Modified</span>
            <span class="ops-detail-value">@Item.LastModified.ToString("yyyy-MM-dd HH:mm:ss zzz")</span>
        </div>
        <div class="ops-detail-row">
            <span class="ops-detail-label">Op Count</span>
            <span class="ops-detail-value">
                <span class="ops-badge ops-badge-muted">@Item.OpCount</span>
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public DocumentInfo Item { get; set; } = default!;
}
