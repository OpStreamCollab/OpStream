@* ── BranchRef DataGrid (QuickGrid) ───────────────────────────── *@

<div class="ops-datagrid-wrapper">
    <div class="ops-datagrid-header">
        <h3>🔀 Branches</h3>
        <span class="ops-datagrid-count">@FilteredItems.Count() items</span>
    </div>

    <div class="ops-datagrid-filter-bar">
        <input type="search"
               class="ops-filter-input"
               placeholder="Filter by name or branch ID…"
               @bind="filterText"
               @bind:event="oninput" />
    </div>

    <div class="ops-datagrid-body">
        <QuickGrid Items="FilteredItems"
                   Pagination="pagination"
                   Theme="ops-quickgrid"
                   Class="ops-quickgrid-table">

            <PropertyColumn Property="@(x => x.Name)"
                            Title="Name"
                            Sortable="true"
                            IsDefaultSortColumn="true" />

            <PropertyColumn Property="@(x => x.BranchId)"
                            Title="Branch ID"
                            Sortable="true" />

            <PropertyColumn Property="@(x => x.PhysicalDocumentId)"
                            Title="Physical Doc ID"
                            Sortable="true" />

            <TemplateColumn Title="Fork Parent"
                            SortBy="GridSort<BranchRef>.ByAscending(x => x.ForkParentBranchId ?? string.Empty)">
                @if (context.ForkParentBranchId is not null)
                {
                    <span class="ops-mono">@context.ForkParentBranchId</span>
                }
                else
                {
                    <span class="ops-null-value">— root —</span>
                }
            </TemplateColumn>

            <PropertyColumn Property="@(x => x.ForkRevision)"
                            Title="Fork Rev"
                            Sortable="true" />

            <PropertyColumn Property="@(x => x.CreatedAt)"
                            Title="Created At"
                            Format="yyyy-MM-dd HH:mm:ss"
                            Sortable="true" />

            <TemplateColumn Title="Read-Only"
                            SortBy="GridSort<BranchRef>.ByAscending(x => x.IsReadOnly)">
                @if (context.IsReadOnly)
                {
                    <span class="ops-boolean-true">Yes</span>
                }
                else
                {
                    <span class="ops-boolean-false">No</span>
                }
            </TemplateColumn>
        </QuickGrid>
    </div>

    <Paginator State="pagination" />
</div>

@code {
    [Parameter, EditorRequired]
    public IEnumerable<BranchRef> Items { get; set; } = [];

    [Parameter]
    public int PageSize { get; set; } = 10;

    private string filterText = string.Empty;
    private PaginationState pagination = default!;

    protected override void OnInitialized()
        => pagination = new PaginationState { ItemsPerPage = PageSize };

    private IQueryable<BranchRef> FilteredItems =>
        string.IsNullOrWhiteSpace(filterText)
            ? Items.AsQueryable()
            : Items.Where(x =>
                  x.Name.Contains(filterText, StringComparison.OrdinalIgnoreCase) ||
                  x.BranchId.Contains(filterText, StringComparison.OrdinalIgnoreCase))
                   .AsQueryable();
}
