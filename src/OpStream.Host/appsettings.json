{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpStream": {
    "Transports": "signalr",
    "Engines": "text,json",
    "SignalR": { "Path": "/collab" },
    "WebSockets": { "Path": "/collab-ws" },
    "Storage": { "Provider": "memory" },
    "Backplane": { "Provider": "local" }
  }
}
