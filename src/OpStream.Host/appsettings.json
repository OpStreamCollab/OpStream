{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpStream": {
    "Transports": "signalr,websockets",
    "Engines": "text,json,rich-text,form",
    "SignalR": { "Path": "/collab" },
    "WebSockets": { "Path": "/collab-ws" },
    "Storage": {
      "Provider": "memory"

    },
    "Backplane": { "Provider": "local" }
  }
}
