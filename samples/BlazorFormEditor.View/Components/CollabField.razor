@* Thin collaborative field. Declares which model property it wraps (via the
   strongly-typed <c>For</c> expression) and renders awareness chrome — a colored
   border + "<name> is editing" badge and a disabled fieldset so two users can't
   edit the same field at once. All sync/awareness logic lives in CollabForm,
   reached through the cascaded <c>ICollabFormContext</c>. *@

@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable

<div class="collab-field @(Class) @(_locked ? "locked" : "")"
     style="@(_locked ? $"--lock-color:{_editor!.Color};" : null)"
     @onfocusin="OnFocusIn"
     @onfocusout="OnFocusOut">

    <div class="collab-field-head">
        @if (!string.IsNullOrEmpty(Label))
        {
            <label>@Label</label>
        }
        @if (_locked)
        {
            <span class="lock-badge" style="background:@_editor!.Color">@_editor!.Name is editing…</span>
        }
        @if (Context?.AllowComments == true && _commentCount > 0)
        {
            <button class="collab-comment-indicator"
                    title="@_commentCount comment(s) — click to view"
                    @onclick="OnShowComments" @onclick:stopPropagation>
                💬 @_commentCount
            </button>
        }
    </div>

    <fieldset class="collab-field-inner" disabled="@_locked">
        @ChildContent
    </fieldset>
</div>

@code {
    [Parameter, EditorRequired] public Expression<Func<TValue>> For { get; set; } = default!;
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [CascadingParameter] public ICollabFormContext? Context { get; set; }

    private string _fieldName = "";
    private FieldEditor? _editor;
    private bool _locked => _editor is not null;
    private int _commentCount;
    private ICollabFormContext? _subscribed;

    protected override void OnParametersSet()
    {
        _fieldName = FieldIdentifier.Create(For).FieldName;

        if (!ReferenceEquals(_subscribed, Context))
        {
            if (_subscribed is not null) _subscribed.StateChanged -= OnContextChanged;
            _subscribed = Context;
            if (_subscribed is not null) _subscribed.StateChanged += OnContextChanged;
        }

        RefreshFromContext();
    }

    private void OnContextChanged()
    {
        RefreshFromContext();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshFromContext()
    {
        _editor = Context?.EditorOf(_fieldName);
        _commentCount = Context?.CommentsForField(_fieldName).Count ?? 0;
    }

    private Task OnFocusIn() => Context?.NotifyFocusAsync(_fieldName) ?? Task.CompletedTask;
    private Task OnFocusOut() => Context?.NotifyBlurAsync(_fieldName) ?? Task.CompletedTask;
    private void OnShowComments() => Context?.OpenFieldComments(_fieldName);

    public void Dispose()
    {
        if (_subscribed is not null) _subscribed.StateChanged -= OnContextChanged;
    }
}
