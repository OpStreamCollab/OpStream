@* Reusable demo body for the collaborative Blazorise rich-text sample. No @page
   so it can be mounted at "/" by the standalone host and at "/samples/rich-text"
   by OpStream.DemoHost. The Blazorise/Bootstrap/FontAwesome CSS is injected here
   via <HeadContent> (scoped to this page); opstream-quill-adapter.js is loaded by
   the component itself, so no host App.razor changes are needed. *@
@using System.Text
@using System.Text.Json
@using Blazorise.RichTextEdit
@implements IAsyncDisposable
@inject IOpStreamClient Client
@inject IJSRuntime JS

<PageTitle>OpStream — Collaborative Rich-Text Editor</PageTitle>

<HeadContent>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="_content/Blazorise.Icons.FontAwesome/v6/css/all.min.css" rel="stylesheet">
    <link href="_content/Blazorise/blazorise.css?v=2.1.3.0" rel="stylesheet" />
    <link href="_content/Blazorise.Bootstrap5/blazorise.bootstrap5.css?v=2.1.3.0" rel="stylesheet" />
</HeadContent>

<Container Fluid Padding="Padding.Is3">
    <Row>
        <Column ColumnSize="ColumnSize.Is8.OnDesktop.Is12.OnTablet">
            <Card>
                <CardHeader>
                    <Div Display="Display.Flex" Flex="Flex.AlignItems.Center" Flex2="Flex.JustifyContent.Between">
                        <Div>
                            <CardTitle Size="HeadingSize.Is4" Margin="Margin.Is0">
                                <Icon Name="IconName.Edit" /> Collaborative rich-text document
                            </CardTitle>
                            <Small TextColor="TextColor.Muted">
                                doc: <Code>@DocumentId</Code> · rev: <Code>@currentRevision</Code> ·
                                @if ( joined )
                                {
                                    <Span Class="awareness-dot" Style="@($"background:{myColor}")"></Span>
                                    <Span Margin="Margin.Is1.FromStart">@myName</Span>
                                }
                                else
                                {
                                    <Span>@statusMessage</Span>
                                }
                            </Small>
                        </Div>
                        <Badge Color="@(joined ? Color.Success : Color.Warning)">@statusMessage</Badge>
                    </Div>
                </CardHeader>
                <CardBody>
                    <div id="@EditorElementId">
                        <RichTextEdit @ref="editor"
                                      Theme="RichTextEditTheme.Snow"
                                      PlaceHolder="Start typing — every keystroke streams as a rich-text op."
                                      ReadOnly="@(!joined)"
                                      SubmitOnEnter="false"
                                      ToolbarPosition="Placement.Top">
                            <Toolbar>
                                <RichTextEditToolbarGroup>
                                    <RichTextEditToolbarButton Action="RichTextEditAction.Bold" />
                                    <RichTextEditToolbarButton Action="RichTextEditAction.Italic" />
                                    <RichTextEditToolbarButton Action="RichTextEditAction.Underline" />
                                </RichTextEditToolbarGroup>
                                <RichTextEditToolbarGroup>
                                    <RichTextEditToolbarButton Action="RichTextEditAction.List" Value="ordered" />
                                    <RichTextEditToolbarButton Action="RichTextEditAction.List" Value="bullet" />
                                </RichTextEditToolbarGroup>
                                <RichTextEditToolbarGroup>
                                    <RichTextEditToolbarSelect Action="RichTextEditAction.Size">
                                        <RichTextEditToolbarSelectItem Value="small" />
                                        <RichTextEditToolbarSelectItem Selected />
                                        <RichTextEditToolbarSelectItem Value="large" />
                                        <RichTextEditToolbarSelectItem Value="huge">Huge</RichTextEditToolbarSelectItem>
                                    </RichTextEditToolbarSelect>
                                </RichTextEditToolbarGroup>
                            </Toolbar>
                        </RichTextEdit>
                    </div>
                </CardBody>
                <CardFooter>
                    <Small TextColor="TextColor.Muted">
                        <Icon Name="IconName.Server" Margin="Margin.Is1.FromEnd" />
                        Powered by <Code>IOpStreamClient</Code> over SignalR · document type <Code>rich-text</Code>
                    </Small>
                </CardFooter>
            </Card>
        </Column>

        <Column ColumnSize="ColumnSize.Is4.OnDesktop.Is12.OnTablet">
            <AwarenessPanel Peers="peers"
                            Activity="activity"
                            Joined="joined"
                            MyName="@myName"
                            MyColor="@myColor" />

            <CommentsPanel Comments="comments"
                           Peers="peers"
                           MyPeerId="@peerId"
                           MyName="@myName"
                           MyColor="@myColor"
                           OnCreateRoot="CreateRootCommentAsync"
                           OnReply="ReplyToCommentAsync"
                           OnResolve="ResolveCommentAsync"
                           OnDelete="DeleteCommentAsync" />
        </Column>
    </Row>
</Container>

@code {
    private const string DocumentId = "demo-doc";
    private const string DocumentType = "rich-text";

    private static readonly string[] Palette =
    {
        "#e57373","#64b5f6","#81c784","#ffb74d","#ba68c8","#4db6ac",
        "#f06292","#9575cd","#7986cb","#a1887f","#90a4ae","#dce775",
    };

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    };

    private readonly string EditorElementId = $"opstream-editor-{Guid.NewGuid():N}";

    private RichTextEdit? editor;
    private DotNetObjectReference<RichTextEditorDemo>? selfRef;

    private bool joined;
    private bool namePrompted;
    private long currentRevision;
    private string statusMessage = "waiting for name…";

    private string peerId = "";
    private string myName = "";
    private string myColor = Palette[0];

    private int selectionIndex;
    private int selectionLength;

    private readonly Dictionary<string, PeerInfo> peers = new( StringComparer.Ordinal );
    private readonly List<ActivityEntry> activity = new();
    private readonly List<CommentDto> comments = new();

    protected override async Task OnAfterRenderAsync( bool firstRender )
    {
        if ( !firstRender || namePrompted ) return;
        namePrompted = true;

        // Load the Quill bridge (sets window.OpStreamQuill) from the RCL's static assets.
        await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazoriseRichTextEditor.View/opstream-quill-adapter.js" );

        // Plain browser prompt — simplest possible identity flow, no Blazorise
        // modal lifecycle to fight with. The user can re-prompt by reloading.
        string? input = null;
        while ( string.IsNullOrWhiteSpace( input ) )
        {
            input = await JS.InvokeAsync<string?>( "prompt",
                "What name should others see?", "" );
        }

        await JoinAsync( input.Trim() );
    }

    private async Task JoinAsync( string name )
    {
        myName = name;
        myColor = PickColor( name );
        statusMessage = "connecting…";
        StateHasChanged();

        // 1. Wire up framework events BEFORE joining so we never miss the first ops.
        Client.OnReceiveOp += HandleRemoteOpAsync;
        Client.OnReceiveAwareness += HandleAwarenessAsync;
        Client.OnPeerDisconnected += HandlePeerDisconnected;
        Client.OnCommentCreated += HandleCommentCreatedAsync;
        Client.OnCommentUpdated += HandleCommentUpdatedAsync;
        Client.OnCommentDeleted += HandleCommentDeletedAsync;
        Client.OnDisconnected += HandleTransportClosed;

        try
        {
            var join = await Client.ConnectAndJoinAsync( DocumentId, DocumentType );
            currentRevision = join.Revision;
            peerId = $"local-{Guid.NewGuid():N}"; // resolved later via awareness self-echo if needed

            // Awareness peers known on join
            foreach ( var state in join.Awareness ) ApplyAwareness( state );

            // 2. Attach the Quill bridge AFTER Blazorise has finished its own init.
            selfRef = DotNetObjectReference.Create( this );
            await JS.InvokeAsync<bool>( "OpStreamQuill.attach", EditorElementId, selfRef );

            // 3. Push the initial snapshot into Quill.
            if ( !join.Snapshot.IsEmpty )
            {
                var snapshotJson = Encoding.UTF8.GetString( join.Snapshot.Span );
                await JS.InvokeAsync<int>( "OpStreamQuill.setSnapshot", EditorElementId, snapshotJson );
            }

            joined = true;
            statusMessage = "connected";

            // 4. Publish our identity and load existing comments.
            await PublishAwarenessAsync( "joined the document" );
            try
            {
                var initial = await Client.ListOpenCommentsAsync( DocumentId );
                comments.Clear();
                comments.AddRange( initial );
            }
            catch ( Exception ex )
            {
                Console.Error.WriteLine( $"ListOpenComments failed: {ex.Message}" );
            }

            StateHasChanged();
        }
        catch ( Exception ex )
        {
            statusMessage = $"error: {ex.Message}";
            joined = false;
            StateHasChanged();
        }
    }

    // ─── Local → server ──────────────────────────────────────────────────────

    [JSInvokable]
    public async Task OnLocalOp( string opJson )
    {
        if ( !joined ) return;
        var payload = Encoding.UTF8.GetBytes( opJson );
        var result = await Client.SendOpAsync( DocumentId, payload, currentRevision );
        if ( result.Success )
        {
            currentRevision = result.NewRevision;
            await PublishAwarenessAsync( "edited the document" );
            await InvokeAsync( StateHasChanged );
        }
        else
        {
            Console.Error.WriteLine( $"SendOp rejected: {result.ErrorMessage}" );
        }
    }

    [JSInvokable]
    public Task OnSelectionChanged( int index, int length )
    {
        selectionIndex = index;
        selectionLength = length;
        return Task.CompletedTask;
    }

    // ─── Server → local ──────────────────────────────────────────────────────

    private async Task HandleRemoteOpAsync( ReadOnlyMemory<byte> payload, long newRevision )
    {
        currentRevision = newRevision;
        var opJson = Encoding.UTF8.GetString( payload.Span );
        await JS.InvokeVoidAsync( "OpStreamQuill.applyRemoteOp", EditorElementId, opJson );
        await InvokeAsync( StateHasChanged );
    }

    private Task HandleAwarenessAsync( IEnumerable<AwarenessState> states )
    {
        foreach ( var state in states ) ApplyAwareness( state );
        return InvokeAsync( StateHasChanged );
    }

    private void HandlePeerDisconnected( string disconnectedPeerId )
    {
        if ( peers.Remove( disconnectedPeerId, out var info ) )
        {
            activity.Insert( 0, new ActivityEntry(
                disconnectedPeerId, info.Name, info.Color, "left the document", DateTimeOffset.UtcNow ) );
            TrimActivity();
        }
        _ = InvokeAsync( StateHasChanged );
    }

    private Task HandleCommentCreatedAsync( CommentDto c ) => UpsertCommentAsync( c );
    private Task HandleCommentUpdatedAsync( CommentDto c ) => UpsertCommentAsync( c );

    private Task HandleCommentDeletedAsync( CommentDeletedDto msg )
    {
        comments.RemoveAll( c => c.Id == msg.CommentId || c.ParentCommentId == msg.CommentId );
        return InvokeAsync( StateHasChanged );
    }

    private void HandleTransportClosed( Exception? ex )
    {
        joined = false;
        statusMessage = ex is null ? "disconnected" : $"disconnected: {ex.Message}";
        _ = InvokeAsync( StateHasChanged );
    }

    private Task UpsertCommentAsync( CommentDto comment )
    {
        var idx = comments.FindIndex( c => c.Id == comment.Id );
        if ( idx >= 0 ) comments[idx] = comment;
        else comments.Add( comment );
        return InvokeAsync( StateHasChanged );
    }

    // ─── Awareness helpers ───────────────────────────────────────────────────

    private async Task PublishAwarenessAsync( string lastAction )
    {
        var payload = new AwarenessPayload( myName, myColor, lastAction, DateTimeOffset.UtcNow );
        var element = JsonSerializer.SerializeToElement( payload, JsonOptions );
        try
        {
            await Client.SendAwarenessAsync( DocumentId, element );
        }
        catch ( Exception ex )
        {
            Console.Error.WriteLine( $"SendAwareness failed: {ex.Message}" );
        }
    }

    private void ApplyAwareness( AwarenessState state )
    {
        string name = "anonymous";
        string color = "#888";
        string action = "";

        try
        {
            var payload = state.Data.Deserialize<AwarenessPayload>( JsonOptions );
            if ( payload is not null )
            {
                name = payload.Name;
                color = payload.Color;
                action = payload.LastAction;
            }
        }
        catch
        {
            // Older clients may send a different shape — keep defaults.
        }

        if ( !peers.TryGetValue( state.PeerId, out var info ) )
        {
            info = new PeerInfo { PeerId = state.PeerId };
            peers[state.PeerId] = info;
        }

        info.Name = name;
        info.Color = color;
        var changed = !string.Equals( info.LastAction, action, StringComparison.Ordinal );
        info.LastAction = action;
        info.LastActionAt = state.LastUpdated;

        if ( changed && !string.IsNullOrEmpty( action ) )
        {
            activity.Insert( 0, new ActivityEntry(
                state.PeerId, name, color, action, state.LastUpdated ) );
            TrimActivity();
        }
    }

    private void TrimActivity()
    {
        const int max = 50;
        if ( activity.Count > max ) activity.RemoveRange( max, activity.Count - max );
    }

    // ─── Comments actions ────────────────────────────────────────────────────

    private async Task CreateRootCommentAsync( string body )
    {
        if ( string.IsNullOrWhiteSpace( body ) ) return;

        // Use the LAST user-made Quill selection, captured by OnSelectionChanged.
        // Re-querying Quill here would return null because focus has moved to the
        // comments textarea — Quill only retains a selection while it owns focus.
        int start = selectionIndex;
        int len = selectionLength;

        var anchorData = JsonSerializer.SerializeToElement( new
        {
            startOffset = start,
            endOffset = start + len,
            biasStart = "left",
            biasEnd = "right",
        }, JsonOptions );

        var cmd = new NewCommentCmd( body.Trim(), new AnchorDto( "richtext", anchorData ), null );

        try
        {
            await Client.CreateCommentAsync( DocumentId, cmd );
            await PublishAwarenessAsync( $"added a comment: \"{Truncate( body, 40 )}\"" );
        }
        catch ( Exception ex )
        {
            Console.Error.WriteLine( $"CreateComment failed: {ex.Message}" );
        }
    }

    private async Task ReplyToCommentAsync( (string ParentId, string Body) input )
    {
        if ( string.IsNullOrWhiteSpace( input.Body ) ) return;
        try
        {
            await Client.CreateCommentAsync( DocumentId,
                new NewCommentCmd( input.Body.Trim(), null, input.ParentId ) );
            await PublishAwarenessAsync( "replied to a comment" );
        }
        catch ( Exception ex )
        {
            Console.Error.WriteLine( $"Reply failed: {ex.Message}" );
        }
    }

    private async Task ResolveCommentAsync( string commentId )
    {
        try
        {
            await Client.ResolveCommentAsync( DocumentId, commentId );
            await PublishAwarenessAsync( "resolved a comment" );
        }
        catch ( Exception ex )
        {
            Console.Error.WriteLine( $"Resolve failed: {ex.Message}" );
        }
    }

    private async Task DeleteCommentAsync( string commentId )
    {
        try
        {
            await Client.DeleteCommentAsync( DocumentId, commentId );
            await PublishAwarenessAsync( "deleted a comment" );
        }
        catch ( Exception ex )
        {
            Console.Error.WriteLine( $"Delete failed: {ex.Message}" );
        }
    }

    // ─── Helpers ─────────────────────────────────────────────────────────────

    private static string PickColor( string seed )
    {
        unchecked
        {
            int hash = 17;
            foreach ( var ch in seed ) hash = hash * 31 + ch;
            return Palette[Math.Abs( hash ) % Palette.Length];
        }
    }

    private static string Truncate( string s, int max ) =>
        s.Length <= max ? s : s.Substring( 0, max ) + "…";

    public async ValueTask DisposeAsync()
    {
        Client.OnReceiveOp -= HandleRemoteOpAsync;
        Client.OnReceiveAwareness -= HandleAwarenessAsync;
        Client.OnPeerDisconnected -= HandlePeerDisconnected;
        Client.OnCommentCreated -= HandleCommentCreatedAsync;
        Client.OnCommentUpdated -= HandleCommentUpdatedAsync;
        Client.OnCommentDeleted -= HandleCommentDeletedAsync;
        Client.OnDisconnected -= HandleTransportClosed;

        try { await JS.InvokeVoidAsync( "OpStreamQuill.detach", EditorElementId ); }
        catch { /* ignore */ }

        selfRef?.Dispose();
        await Client.DisposeAsync();
    }
}
