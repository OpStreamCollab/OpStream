{
  "manifest_version": 3,
  "name": "OpStream Collab (textarea prototype)",
  "version": "0.1.0",
  "description": "Turns any <textarea> or text input on any web page into a live collaborative field backed by an OpStream server.",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content-loader.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "collab/textarea-collab.js",
        "collab/contenteditable-collab.js",
        "collab/sw-port-client.js",
        "collab/WebSocketOpStreamClient.js",
        "collab/ot-text.js"
      ],
      "matches": ["*://*/*"]
    }
  ]
}
