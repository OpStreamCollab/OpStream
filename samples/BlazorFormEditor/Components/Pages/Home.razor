</style>

@code {
    private const string DocumentId = "customer-profile";
    private const string DocumentType = "form";

    private static readonly string[] Palette =
    {
        "#e57373","#64b5f6","#81c784","#ffb74d","#ba68c8","#4db6ac",
        "#f06292","#9575cd","#7986cb","#a1887f","#90a4ae","#dce775",
    };

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    };

    private Customer customer = new();
    private bool submitted = false;

    private bool _joined;
    private bool _started;
    private long _currentRevision;
    private string _statusMessage = "Connecting…";

    private string _peerId = $"peer-{Guid.NewGuid():N}";
    private string _myName = "Anonymous";
    private string _myColor = Palette[0];
    private string _lastActivity = "";
    private string _editingField = "";

    private readonly Dictionary<string, PeerInfo> _peers = new(StringComparer.Ordinal);

    // Field-name discriminators — must match the camelCased property names the
    // FormOtEngine stores in its LWW register map.
    private static class Fields
    {
        public const string FirstName = "firstName";
        public const string LastName = "lastName";
        public const string Email = "email";
        public const string PhoneNumber = "phoneNumber";
        public const string Address = "address";
        public const string City = "city";
        public const string State = "state";
        public const string ZipCode = "zipCode";
        public const string DateOfBirth = "dateOfBirth";
        public const string Gender = "gender";
        public const string IsSubscribed = "isSubscribed";
        public const string Notes = "notes";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        var name = await JS.InvokeAsync<string?>("prompt", "What name should others see?", "");
        _myName = string.IsNullOrWhiteSpace(name) ? "Anonymous" : name.Trim();
        _myColor = PickColor(_myName);

        await ConnectAsync();
    }

    private async Task ConnectAsync()
    {
        Client.OnReceiveOp += HandleRemoteOpAsync;
        Client.OnReceiveAwareness += HandleAwarenessAsync;
        Client.OnPeerDisconnected += HandlePeerDisconnected;
        Client.OnDisconnected += HandleTransportClosed;

        try
        {
            var join = await Client.ConnectAndJoinAsync(DocumentId, DocumentType);
            _currentRevision = join.Revision;

            LoadSnapshot(join.Snapshot);
            foreach (var state in join.Awareness) ApplyAwareness(state);

            _joined = true;
            _statusMessage = "Connected";

            await PublishAwarenessAsync("joined");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Per-field editing presence (soft lock) ─────────────────────────────────

    private async Task OnFieldFocus(string fieldName)
    {
        _editingField = fieldName;
        await PublishAwarenessAsync($"is editing {Label(fieldName)}");
    }

    private async Task OnFieldBlur(string fieldName)
    {
        if (_editingField == fieldName) _editingField = "";
        await PublishAwarenessAsync("");
    }

    /// <summary>Name of the remote peer currently editing <paramref name="fieldName"/>, or null.</summary>
    private string? EditorName(string fieldName) => FieldEditor(fieldName)?.Name;
    private string? EditorColor(string fieldName) => FieldEditor(fieldName)?.Color;

    private PeerInfo? FieldEditor(string fieldName)
    {
        foreach (var p in _peers.Values)
        {
            if (string.Equals(p.EditingField, fieldName, StringComparison.Ordinal))
                return p;
        }
        return null;
    }

    // ── Local → server ─────────────────────────────────────────────────────────

    private async Task SendFieldAsync(string fieldName)
    {
        if (!_joined) return;

        var valueNode = ReadFieldNode(fieldName);
        var op = new JsonObject
        {
            ["$type"] = valueNode is null ? "clr" : "set",
            ["fieldName"] = fieldName,
        };
        if (valueNode is not null) op["value"] = valueNode;
        op["timestamp"] = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        op["peerId"] = _peerId;

        var batch = new JsonObject { ["operations"] = new JsonArray(op) };
        var payload = Encoding.UTF8.GetBytes(batch.ToJsonString());

        try
        {
            var result = await Client.SendOpAsync(DocumentId, payload, _currentRevision);
            if (result.Success)
            {
                _currentRevision = result.NewRevision;
                await PublishAwarenessAsync($"edited {Label(fieldName)}");
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                Console.Error.WriteLine($"SendOp rejected: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"SendOp failed: {ex.Message}");
        }
    }

    // ── Server → local ─────────────────────────────────────────────────────────

    private async Task HandleRemoteOpAsync(ReadOnlyMemory<byte> payload, long newRevision)
    {
        _currentRevision = newRevision;

        using var doc = JsonDocument.Parse(payload);
        if (doc.RootElement.TryGetProperty("operations", out var ops))
        {
            foreach (var op in ops.EnumerateArray())
            {
                if (!op.TryGetProperty("fieldName", out var fn)) continue;
                var fieldName = fn.GetString();
                if (fieldName is null) continue;

                if (op.TryGetProperty("value", out var value))
                    ApplyFieldToModel(fieldName, value);
                else
                    ApplyFieldToModel(fieldName, null); // clear op carries no value
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task HandleAwarenessAsync(IEnumerable<AwarenessState> states)
    {
        foreach (var state in states) ApplyAwareness(state);
        return InvokeAsync(StateHasChanged);
    }

    private void HandlePeerDisconnected(string peerId)
    {
        _peers.Remove(peerId);
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleTransportClosed(Exception? ex)
    {
        _joined = false;
        _statusMessage = ex is null ? "Disconnected" : $"Disconnected: {ex.Message}";
        _ = InvokeAsync(StateHasChanged);
    }

    // ── Awareness ──────────────────────────────────────────────────────────────

    private async Task PublishAwarenessAsync(string action)
    {
        var payload = new AwarenessPayload(_myName, _myColor, action, _editingField, DateTimeOffset.UtcNow);
        var element = JsonSerializer.SerializeToElement(payload, JsonOptions);
        try { await Client.SendAwarenessAsync(DocumentId, element); }
        catch (Exception ex) { Console.Error.WriteLine($"SendAwareness failed: {ex.Message}"); }
    }

    private void ApplyAwareness(AwarenessState state)
    {
        if (state.PeerId == _peerId) return;

        string name = "anonymous", color = "#888", action = "", editingField = "";
        try
        {
            var payload = state.Data.Deserialize<AwarenessPayload>(JsonOptions);
            if (payload is not null)
            {
                name = payload.Name;
                color = payload.Color;
                action = payload.LastAction;
                editingField = payload.EditingField ?? "";
            }
        }
        catch { /* tolerate older / different shapes */ }

        if (!_peers.TryGetValue(state.PeerId, out var info))
        {
            info = new PeerInfo { PeerId = state.PeerId };
            _peers[state.PeerId] = info;
        }
        info.Name = name;
        info.Color = color;
        info.LastAction = action;
        info.EditingField = editingField;

        if (!string.IsNullOrEmpty(action))
            _lastActivity = $"{name} {action}";
    }

    // ── Field mapping ──────────────────────────────────────────────────────────

    private JsonNode? ReadFieldNode(string fieldName) => fieldName switch
    {
        Fields.FirstName => Str(customer.FirstName),
        Fields.LastName => Str(customer.LastName),
        Fields.Email => Str(customer.Email),
        Fields.PhoneNumber => Str(customer.PhoneNumber),
        Fields.Address => Str(customer.Address),
        Fields.City => Str(customer.City),
        Fields.State => Str(customer.State),
        Fields.ZipCode => Str(customer.ZipCode),
        Fields.DateOfBirth => customer.DateOfBirth is { } d ? JsonValue.Create(d.ToString("yyyy-MM-dd")) : null,
        Fields.Gender => Str(customer.Gender),
        Fields.IsSubscribed => JsonValue.Create(customer.IsSubscribed),
        Fields.Notes => Str(customer.Notes),
        _ => null,
    };

    private void ApplyFieldToModel(string fieldName, JsonElement? valueOrNull)
    {
        bool isNull = valueOrNull is null || valueOrNull.Value.ValueKind == JsonValueKind.Null;
        var v = valueOrNull ?? default;

        switch (fieldName)
        {
            case Fields.FirstName: customer.FirstName = isNull ? "" : v.GetString() ?? ""; break;
            case Fields.LastName: customer.LastName = isNull ? "" : v.GetString() ?? ""; break;
            case Fields.Email: customer.Email = isNull ? "" : v.GetString() ?? ""; break;
            case Fields.PhoneNumber: customer.PhoneNumber = isNull ? null : v.GetString(); break;
            case Fields.Address: customer.Address = isNull ? null : v.GetString(); break;
            case Fields.City: customer.City = isNull ? null : v.GetString(); break;
            case Fields.State: customer.State = isNull ? null : v.GetString(); break;
            case Fields.ZipCode: customer.ZipCode = isNull ? null : v.GetString(); break;
            case Fields.DateOfBirth:
                customer.DateOfBirth = !isNull && DateTime.TryParse(v.GetString(), out var d) ? d : null;
                break;
            case Fields.Gender: customer.Gender = isNull ? "Male" : v.GetString() ?? "Male"; break;
            case Fields.IsSubscribed: customer.IsSubscribed = !isNull && v.GetBoolean(); break;
            case Fields.Notes: customer.Notes = isNull ? null : v.GetString(); break;
        }
    }

    private void LoadSnapshot(ReadOnlyMemory<byte> snapshot)
    {
        if (snapshot.IsEmpty) return;
        using var doc = JsonDocument.Parse(snapshot);
        if (!doc.RootElement.TryGetProperty("fields", out var fields)) return;

        foreach (var field in fields.EnumerateObject())
        {
            if (field.Value.TryGetProperty("value", out var value))
                ApplyFieldToModel(field.Name, value);
        }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    private static JsonNode? Str(string? s) => string.IsNullOrEmpty(s) ? null : JsonValue.Create(s);

    private static string Label(string fieldName) => fieldName switch
    {
        Fields.FirstName => "First Name",
        Fields.LastName => "Last Name",
        Fields.Email => "Email",
        Fields.PhoneNumber => "Phone Number",
        Fields.Address => "Address",
        Fields.City => "City",
        Fields.State => "State",
        Fields.ZipCode => "Zip Code",
        Fields.DateOfBirth => "Date of Birth",
        Fields.Gender => "Gender",
        Fields.IsSubscribed => "Newsletter",
        Fields.Notes => "Notes",
        _ => fieldName,
    };

    private static string PickColor(string seed)
    {
        unchecked
        {
            int hash = 17;
            foreach (var ch in seed) hash = hash * 31 + ch;
            return Palette[Math.Abs(hash) % Palette.Length];
        }
    }

    private void HandleValidSubmit()
    {
        submitted = true;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        Client.OnReceiveOp -= HandleRemoteOpAsync;
        Client.OnReceiveAwareness -= HandleAwarenessAsync;
        Client.OnPeerDisconnected -= HandlePeerDisconnected;
        Client.OnDisconnected -= HandleTransportClosed;

        try { await Client.DisposeAsync(); } catch { /* ignore */ }
    }

    public class Customer
    {
        [Required(ErrorMessage = "First Name is required")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last Name is required")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        public string? PhoneNumber { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? ZipCode { get; set; }

        [DataType(DataType.Date)]
        public DateTime? DateOfBirth { get; set; }

        public string Gender { get; set; } = "Male";
        public bool IsSubscribed { get; set; } = true;
        public string? Notes { get; set; }
    }

    private sealed class PeerInfo
    {
        public required string PeerId { get; init; }
        public string Name { get; set; } = "anonymous";
        public string Color { get; set; } = "#888";
        public string LastAction { get; set; } = "";
