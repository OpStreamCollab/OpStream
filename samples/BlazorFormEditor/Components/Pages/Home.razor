    .collab-status.wait { background: #fff3cd; color: #856404; }

    .collab-rev code { color: #007bff; }

    .collab-peers { display: flex; align-items: center; gap: 0.3rem; }
    .peer-dot {
        width: 12px; height: 12px; border-radius: 50%;
        display: inline-block; border: 1px solid rgba(0,0,0,0.15);
    }
    .peer-dot.me { box-shadow: 0 0 0 2px #fff, 0 0 0 3px currentColor; }

    .collab-activity { margin-left: auto; font-style: italic; color: #888; }

    .collab-fieldset { border: none; padding: 0; margin: 0; min-inline-size: auto; }

    .collab-field {
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 0.4rem 0.6rem;
        margin-bottom: 0.85rem;
        transition: border-color 0.15s, box-shadow 0.15s, background-color 0.15s;
    }

    .collab-field.locked {
        border-color: var(--lock-color, #888);
        background-color: color-mix(in srgb, var(--lock-color, #888) 8%, transparent);
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--lock-color, #888) 25%, transparent);
    }

    .collab-field-head {
