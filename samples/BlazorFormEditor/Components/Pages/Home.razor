@page "/"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using OpStream.Client.Transports
@using OpStream.Shared.Messages
@implements IAsyncDisposable
@inject IOpStreamClient Client
@inject IJSRuntime JS

<PageTitle>Customer Profile</PageTitle>

<div class="customer-form-container">
    <h1>Customer Profile</h1>

    <div class="collab-bar">
        <span class="collab-status @(_joined ? "ok" : "wait")">@_statusMessage</span>
        <span class="collab-rev">doc: <code>@DocumentId</code> · rev: <code>@_currentRevision</code></span>
        <span class="collab-peers">
            @foreach (var p in _peers.Values)
            {
                <span class="peer-dot" style="background:@p.Color" title="@p.Name"></span>
            }
            @if (_joined)
            {
                <span class="peer-dot me" style="background:@_myColor" title="@_myName (you)"></span>
            }
        </span>
        @if (!string.IsNullOrEmpty(_lastActivity))
        {
            <span class="collab-activity">@_lastActivity</span>
        }
    </div>

    <EditForm Model="@customer" OnValidSubmit="HandleValidSubmit" FormName="CustomerProfileForm">
        <DataAnnotationsValidator />

        <fieldset disabled="@(!_joined)" class="collab-fieldset">
        <CollabField FieldName="@Fields.FirstName" Label="First Name"
                     EditorName="@EditorName(Fields.FirstName)" EditorColor="@EditorColor(Fields.FirstName)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputText id="firstName" @bind-Value="customer.FirstName" @bind-Value:after="() => SendFieldAsync(Fields.FirstName)" class="form-control" />
            <ValidationMessage For="@(() => customer.FirstName)" class="text-danger" />
        </CollabField>

        <CollabField FieldName="@Fields.LastName" Label="Last Name"
                     EditorName="@EditorName(Fields.LastName)" EditorColor="@EditorColor(Fields.LastName)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputText id="lastName" @bind-Value="customer.LastName" @bind-Value:after="() => SendFieldAsync(Fields.LastName)" class="form-control" />
            <ValidationMessage For="@(() => customer.LastName)" class="text-danger" />
        </CollabField>

        <CollabField FieldName="@Fields.Email" Label="Email Address"
                     EditorName="@EditorName(Fields.Email)" EditorColor="@EditorColor(Fields.Email)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputText id="email" @bind-Value="customer.Email" @bind-Value:after="() => SendFieldAsync(Fields.Email)" class="form-control" type="email" />
            <ValidationMessage For="@(() => customer.Email)" class="text-danger" />
        </CollabField>

        <CollabField FieldName="@Fields.PhoneNumber" Label="Phone Number"
                     EditorName="@EditorName(Fields.PhoneNumber)" EditorColor="@EditorColor(Fields.PhoneNumber)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputText id="phone" @bind-Value="customer.PhoneNumber" @bind-Value:after="() => SendFieldAsync(Fields.PhoneNumber)" class="form-control" />
        </CollabField>

        <CollabField FieldName="@Fields.Address" Label="Street Address"
                     EditorName="@EditorName(Fields.Address)" EditorColor="@EditorColor(Fields.Address)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputText id="address" @bind-Value="customer.Address" @bind-Value:after="() => SendFieldAsync(Fields.Address)" class="form-control" />
        </CollabField>

        <div class="row">
            <CollabField FieldName="@Fields.City" Label="City" Class="col"
                         EditorName="@EditorName(Fields.City)" EditorColor="@EditorColor(Fields.City)"
                         OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
                <InputText id="city" @bind-Value="customer.City" @bind-Value:after="() => SendFieldAsync(Fields.City)" class="form-control" />
            </CollabField>
            <CollabField FieldName="@Fields.State" Label="State" Class="col"
                         EditorName="@EditorName(Fields.State)" EditorColor="@EditorColor(Fields.State)"
                         OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
                <InputSelect id="state" @bind-Value="customer.State" @bind-Value:after="() => SendFieldAsync(Fields.State)" class="form-control">
                    <option value="">Select a state...</option>
                    <option value="AL">Alabama</option>
                    <option value="AK">Alaska</option>
                    <option value="AZ">Arizona</option>
                    <option value="CA">California</option>
                    <option value="FL">Florida</option>
                    <option value="GA">Georgia</option>
                    <option value="IL">Illinois</option>
                    <option value="NY">New York</option>
                    <option value="TX">Texas</option>
                    <option value="WA">Washington</option>
                </InputSelect>
            </CollabField>
            <CollabField FieldName="@Fields.ZipCode" Label="Zip Code" Class="col"
                         EditorName="@EditorName(Fields.ZipCode)" EditorColor="@EditorColor(Fields.ZipCode)"
                         OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
                <InputText id="zip" @bind-Value="customer.ZipCode" @bind-Value:after="() => SendFieldAsync(Fields.ZipCode)" class="form-control" />
            </CollabField>
        </div>

        <CollabField FieldName="@Fields.DateOfBirth" Label="Date of Birth"
                     EditorName="@EditorName(Fields.DateOfBirth)" EditorColor="@EditorColor(Fields.DateOfBirth)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputDate id="dob" @bind-Value="customer.DateOfBirth" @bind-Value:after="() => SendFieldAsync(Fields.DateOfBirth)" class="form-control" />
        </CollabField>

        <CollabField FieldName="@Fields.Gender" Label="Gender"
                     EditorName="@EditorName(Fields.Gender)" EditorColor="@EditorColor(Fields.Gender)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputRadioGroup @bind-Value="customer.Gender" @bind-Value:after="() => SendFieldAsync(Fields.Gender)">
                <div class="radio-options">
                    <div class="radio-option">
                        <InputRadio Value="@("Male")" id="genderMale" />
                        <label for="genderMale">Male</label>
                    </div>
                    <div class="radio-option">
                        <InputRadio Value="@("Female")" id="genderFemale" />
                        <label for="genderFemale">Female</label>
                    </div>
                    <div class="radio-option">
                        <InputRadio Value="@("Other")" id="genderOther" />
                        <label for="genderOther">Other</label>
                    </div>
                </div>
            </InputRadioGroup>
        </CollabField>

        <CollabField FieldName="@Fields.IsSubscribed" Label="Newsletter"
                     EditorName="@EditorName(Fields.IsSubscribed)" EditorColor="@EditorColor(Fields.IsSubscribed)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <div class="checkbox-container">
                <InputCheckbox id="isSubscribed" @bind-Value="customer.IsSubscribed" @bind-Value:after="() => SendFieldAsync(Fields.IsSubscribed)" class="form-check-input" />
                <label for="isSubscribed" class="form-check-label">Subscribe to newsletter</label>
            </div>
        </CollabField>

        <CollabField FieldName="@Fields.Notes" Label="Notes"
                     EditorName="@EditorName(Fields.Notes)" EditorColor="@EditorColor(Fields.Notes)"
                     OnFocus="OnFieldFocus" OnBlur="OnFieldBlur">
            <InputTextArea id="notes" @bind-Value="customer.Notes" @bind-Value:after="() => SendFieldAsync(Fields.Notes)" class="form-control" rows="3" />
        </CollabField>
        </fieldset>

        <button type="submit" class="btn btn-primary" disabled="@(!_joined)">Save Profile</button>
    </EditForm>

    @if (submitted)
    {
        <div class="alert alert-success">
            <strong>Success!</strong> Customer profile has been simulated as saved.
        </div>
    }
</div>

<style>
    .customer-form-container {
        max-width: 700px;
        margin: 2rem auto;
        padding: 2rem;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        border: 1px solid #e0e0e0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    h1 {
        color: #333;
        margin-bottom: 1.5rem;
        text-align: center;
        font-weight: 600;
    }

    .collab-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        margin-bottom: 1.5rem;
